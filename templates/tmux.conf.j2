# --- Managed by Ansible ---

# Quality of Life
set -g mouse on
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on

# ==============================================
# Nested Tmux Logic (The F12 Toggle)
# ==============================================

# We define a variable to track if the "Outer" session is active
bind -T root F12  \
  set prefix None \;\
  set key-table off \;\
  set status-style "fg=colour245,bg=colour238" \;\
  if -F '#{pane_in_mode}' 'send-keys -X cancel' \;\
  refresh-client -S \;\

bind -T off F12 \
  set -u prefix \;\
  set -u key-table \;\
  set -u status-style \;\
  refresh-client -S

# Simple status bar that shows if we are "OFF" (passed through)
set -g status-right ' #{? episcopal_off,#[fg=red]● OFF,#[fg=green]● ON} | %H:%M '
